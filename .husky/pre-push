#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Pre-push hook - runs before pushing to remote
# Ensures code quality gates are met before sharing with team

set -e  # Exit on first error

echo "🔍 Running pre-push checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check 1: Verify git is healthy
echo "${YELLOW}[1/5]${NC} Checking git status..."
if [ -n "$(git status -s)" ]; then
  echo "${YELLOW}⚠️  Warning: Uncommitted changes detected${NC}"
fi

# Check 2: Run linting
echo "${YELLOW}[2/5]${NC} Running ESLint..."
if ! npm run lint > /dev/null 2>&1; then
  echo "${RED}❌ ESLint failed. Fix linting errors before pushing.${NC}"
  echo "   Run: npm run lint:fix"
  exit 1
fi
echo "${GREEN}✅ ESLint passed${NC}"

# Check 3: Run type checking
echo "${YELLOW}[3/5]${NC} Running TypeScript compiler..."
if ! npm run typecheck > /dev/null 2>&1; then
  echo "${RED}❌ TypeScript compilation failed.${NC}"
  exit 1
fi
echo "${GREEN}✅ TypeScript passed${NC}"

# Check 4: Check for test.only()
echo "${YELLOW}[4/5]${NC} Checking for test.only() or test.skip()..."
if git diff --cached --name-only | grep -E '\.(ts|tsx)$' | xargs grep -l "test\.only\|test\.skip" 2>/dev/null; then
  echo "${RED}❌ Found test.only() or test.skip() in staged files.${NC}"
  echo "   Remove debug test markers before pushing."
  exit 1
fi
echo "${GREEN}✅ No test debug markers found${NC}"

# Check 5: Verify no credentials in code
echo "${YELLOW}[5/5]${NC} Scanning for exposed credentials..."
DANGEROUS_PATTERNS="password.*=|api_key|secret.*=|aws_secret"
if git diff --cached | grep -iE "${DANGEROUS_PATTERNS}" > /dev/null 2>&1; then
  echo "${RED}❌ Potential credentials detected in staged changes.${NC}"
  echo "   Please verify no secrets are being committed."
  exit 1
fi
echo "${GREEN}✅ No obvious credential exposure${NC}"

echo ""
echo "${GREEN}✅ All pre-push checks passed!${NC}"
echo "🚀 Ready to push to remote"
