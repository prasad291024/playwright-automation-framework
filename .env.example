# Environment
TEST_EXECUTION_ENV=QA

# Web UI
GOOGLE_URL=https://www.google.com/
SEARCH_KEYWORDS=Breaking news
BASE_URL=https://your-web-app.com
APP=local
FORCE_AUTH_SETUP=0
SKIP_GLOBAL_AUTH_SETUP=0
# Archived app: VWO stays here for future reactivation, but it is not part of active CI execution.
VWO_BASE_URL=https://app.vwo.com
# Optional VWO login overrides for org/account-specific routes
# Full override (use when login is hosted at a custom URL)
VWO_LOGIN_URL=
# Relative path override (defaults to /#/login)
VWO_LOGIN_PATH=
# Optional query string (no leading ?). Example: accountId=123&redirect=%2Fdashboard
VWO_LOGIN_QUERY=
CURA_BASE_URL=https://katalon-demo-cura.herokuapp.com

# API
BASE_API_URL=https://restful-booker.herokuapp.com

# Credentials
USERNAME=your_username
PASSWORD=your_password
# Archived app credentials: only needed if VWO is reactivated with valid org-owned access.
VWO_EMAIL=your_vwo_email
VWO_PASSWORD=your_vwo_password
CURA_USERNAME=John Doe
CURA_PASSWORD=ThisIsNotAPassword
SAUCEDEMO_USERNAME=standard_user
SAUCEDEMO_PASSWORD=secret_sauce
ORANGEHRM_USERNAME=Admin
ORANGEHRM_PASSWORD=admin123

# Realtime server endpoint used by tests to emit server-side events (POST)
# Example: /api/realtime/emit or /ws/emit
REALTIME_EMIT_PATH=/api/realtime/emit
