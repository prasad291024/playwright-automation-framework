# Environment
TEST_EXECUTION_ENV=QA

# Web UI
GOOGLE_URL=https://www.google.com/
SEARCH_KEYWORDS=Breaking news
BASE_URL=https://your-web-app.com
APP=local
FORCE_AUTH_SETUP=0
VWO_BASE_URL=https://app.vwo.com
CURA_BASE_URL=https://katalon-demo-cura.herokuapp.com

# API
BASE_API_URL=https://restful-booker.herokuapp.com

# Credentials
USERNAME=your_username
PASSWORD=your_password
VWO_EMAIL=your_vwo_email
VWO_PASSWORD=your_vwo_password
CURA_USERNAME=John Doe
CURA_PASSWORD=ThisIsNotAPassword

# Realtime server endpoint used by tests to emit server-side events (POST)
# Example: /api/realtime/emit or /ws/emit
REALTIME_EMIT_PATH=/api/realtime/emit
